# Data (large, regenerable from raw source or the pipeline itself)
data/raw/*
data/raw/**/*
!data/raw/.gitkeep
!data/raw/*/
!data/raw/*/.gitkeep
data/processed/*
data/processed/**/*
!data/processed/.gitkeep
!data/processed/*/
!data/processed/*/.gitkeep

# Model checkpoints (large, regenerable from training)
models/**/*.pt
models/**/*.pth
models/**/*.h5
models/**/*.ckpt
!models/.gitkeep
!models/*/
!models/*/.gitkeep

# Research outputs/artifacts
outputs/**/*.png
outputs/**/*.jpg
outputs/**/*.jpeg
outputs/**/*.pdf
outputs/**/*.csv
outputs/**/*.json
!outputs/.gitkeep
!outputs/*/
!outputs/*/.gitkeep
# Manifests and metric histories are small and intentionally shareable.
runs/**/*.log
runs/**/protocol_smoke*/
!runs/.gitkeep
!runs/*/
!runs/*/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
build/
dist/
.cache/

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS-specific junk
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/

# Environment secrets (if you ever add API keys, wandb, etc.)
.env
